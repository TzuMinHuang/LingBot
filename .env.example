# 🤖 LingBot Environment Configuration Example

# --- Database Settings (PostgreSQL) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
DB_URL=jdbc:postgresql://localhost:5432/lingbot
DB_USERNAME=chatuser
DB_PASSWORD=your_db_password

# --- Redis Settings ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- AnythingLLM Settings ---
# API_KEY 和 WORKSPACE_SLUG 供 backend-service 使用
ANYTHINGLLM_API_KEY=your_anything_llm_api_key
ANYTHINGLLM_WORKSPACE_SLUG=your_workspace_slug
# JWT_SECRET 已移至 data/anythingllm/.env（見 anythingllm/.env.example）

# --- LiteLLM Settings (Optional) ---
LITELLM_MASTER_KEY=your_litellm_master_key

# --- Component Specific DB Settings ---
ANYTHINGLLM_DB_USER=anythingllm_user
ANYTHINGLLM_DB_PASSWORD=anythingllm_pass
LITELLM_DB_USER=litellm_user
LITELLM_DB_PASSWORD=litellm_pass
