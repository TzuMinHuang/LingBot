# =============================================================
# AnythingLLM Configuration
# =============================================================
# 使用方式：
#   1. 複製此檔案到 ./data/anythingllm/.env
#      cp anythingllm/.env.example data/anythingllm/.env
#   2. 填入實際的 secret 值（標示 your_xxx 的欄位）
#   3. 啟動 docker compose --profile infra up -d
#
# 遷移（從舊版升級）：
#   舊版 storage 掛載在 ./data/anythingllm/，新版改為 ./data/anythingllm/storage/
#   如有既有資料，請執行：
#     cd data/anythingllm
#     mkdir -p storage
#     mv documents models plugins vector-cache comkey push-notifications storage/
#
# 注意：DATABASE_URL 和 STORAGE_DIR 由 docker-compose.yml 管理，
#       不需要在此檔案中設定。
# =============================================================
STORAGE_DIR='/app/server/storage'
# --- Auth ---
# Auto-dump ENV from system call on 18:12:22 GMT+0000 (Coordinated Universal Time)
SIG_KEY='77dd9dd8b737842719b725ee2699d6af08da64522b8426422ec1f3b29bc2a9c4'
SIG_SALT='9c9b32ff5ec1cb892e0f80624bbf76371932951080431a5ccca36da583b34552'
JWT_SECRET='6f6c3e40144309baab84cdf79e758bb394af2a07e759dc7de4a48f3f9b469560'

# --- LLM Provider (via LiteLLM proxy) ---
GENERIC_OPEN_AI_MODEL_PREF='llama3.1'
GENERIC_OPEN_AI_MODEL_TOKEN_LIMIT='4096'
GENERIC_OPEN_AI_API_KEY='qazwsxedc'
GENERIC_OPEN_AI_MAX_TOKENS='1024'
EMBEDDING_ENGINE='generic-openai'
EMBEDDING_BASE_PATH='http://litellm_proxy:4000/v1'

# --- Embedding Provider (via LiteLLM proxy) ---
LLM_PROVIDER='generic-openai'
EMBEDDING_MODEL_PREF='mxbai-embed-large'
GENERIC_OPEN_AI_BASE_PATH='http://litellm_proxy:4000/v1'
EMBEDDING_MODEL_MAX_CHUNK_LENGTH='500'
GENERIC_OPEN_AI_EMBEDDING_API_KEY='qazwsxedc'
GENERIC_OPEN_AI_EMBEDDING_MAX_CONCURRENT_CHUNKS='500'

# --- Vector Database (pgvector) ---
VECTOR_DB='pgvector'
PGVECTOR_CONNECTION_STRING='postgresql://anythingllm_user:anythingllm_pass@postgres:5432/anythingllm_db'
PGVECTOR_TABLE_NAME='anythingllm_vectors'