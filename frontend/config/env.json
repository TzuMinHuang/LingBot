{
  "ui": {
    "title": "Industrial AI",
    "locale": "zh-TW",
    "maxInputLength": 500,
    "streamSpeed": 18,
    "idleTimeoutMs": 300000,
    "idleSuggestMs": 240000,
    "suggestCacheMs": 3600000,
    "defaultSuggestions": [
      "產品規格查詢", "保固期限說明", "訂單狀態查詢", "技術支援聯繫方式",
      "退換貨流程", "韌體更新方式", "帳號相關問題", "付款方式說明"
    ]
  },
  "allowedDomains": [
    "localhost",
    "127.0.0.1",
    "test-chatbot.example.com",
    "chatbot.example.com"
  ],
  "hostEnvMap": {
    "localhost":                 "dev",
    "127.0.0.1":                "dev",
    "test-chatbot.example.com": "test",
    "chatbot.example.com":      "prod"
  },
  "envMap": {
    "dev": {
      "apiBase":         "",
      "chatbotUrl":      "/pages/chatbot.html",
      "authValidateUrl": "/api/auth/validate",
      "authSsoUrl":      "/api/auth/sso"
    },
    "test": {
      "apiBase":         "https://test-chatbot.example.com",
      "chatbotUrl":      "https://test-chatbot.example.com/pages/chatbot.html",
      "authValidateUrl": "https://test-chatbot.example.com/api/auth/validate",
      "authSsoUrl":      "https://test-chatbot.example.com/api/auth/sso"
    },
    "prod": {
      "apiBase":         "https://chatbot.example.com",
      "chatbotUrl":      "https://chatbot.example.com/pages/chatbot.html",
      "authValidateUrl": "https://chatbot.example.com/api/auth/validate",
      "authSsoUrl":      "https://chatbot.example.com/api/auth/sso"
    }
  }
}
